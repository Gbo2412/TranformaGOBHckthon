# API del Despacho Presidencial (con default; sobrescribir solo si cambia)
DP_API_BASE_URL=https://www.presidencia.gob.pe/api/consulta-expedientes/index.php

# Claude (Anthropic) — para el agente
ANTHROPIC_API_KEY=sk-ant-...

# Envío de correo — Gmail API OAuth2
GMAIL_CLIENT_ID=<client_id_de_google_cloud>
GMAIL_CLIENT_SECRET=<client_secret_de_google_cloud>
GMAIL_REFRESH_TOKEN=<refresh_token_de_la_cuenta_remitente>
EMAIL_FROM=Asistente de Despacho Presidencial <asistente.de.despacho.hackaton@gmail.com>

# Rate limiting
RATE_LIMIT_PER_MIN=30
